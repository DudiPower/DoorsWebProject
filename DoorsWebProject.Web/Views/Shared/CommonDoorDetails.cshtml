@using DoorsWebProject.Web.ViewModels.Door
@model DoorDetailsViewModel

@{
    ViewData["Title"] = "Детайли за вратата";
}

<div class="container mt-5">
    <div class="card shadow-lg border-0 p-4">
        <div class="row g-4">
            <!-- Снимка на вратата -->
            <div class="col-md-6 text-center" id="zoomContainer">
                <img src="@Url.Content(Model.ImageUrl)" alt="Door image" id="doorImage" class="img-fluid rounded shadow-sm"/>
                <div class="zoom-lens" id="zoomLens">
                    <img src="@Model.ImageUrl" alt="Zoomed Door" id="zoomedImage">
                </div>
                <div id="doorTexture"></div>
            </div>

            <!-- Информация за вратата -->
            <div class="col-md-6">
                <h2 class="mb-3">@Model.Model</h2>
                <p class="text-muted">@Model.Description</p>

                <hr />

                <ul class="list-group list-group-flush">      
                    <li class="list-group-item"><strong>Височина:</strong> @Model.Height см</li>
                    <li class="list-group-item"><strong>Ширина:</strong> @Model.Width см</li>
                    <li class="list-group-item"><strong>Дебелина:</strong> @Model.Thickness см</li>
                </ul>

                <div class="mt-4 d-flex gap-2">
                   <div class="quantity-container">
                       <button class="quantity-btn" onclick="decrease()">−</button>
                       <input id="quantity" class="quantity-input" type="text" value="1" readonly>
                       <button class="quantity-btn" onclick="increase()">+</button>
                   </div>
                </div>

                <div class="color-container" >
                @foreach (var color in Model.DoorColors)
                {
                    <div class="color"
                         style="
                    width:30px;
                    height:30px;
                    background-color:@color.HexCode;
                    border-radius:50%;
                    border:1px solid black;
                    cursor:pointer;"
                         data-texture-url="@Url.Content(color.TextureUrl)"
                         data-color="@color.HexCode"
                         title="@color.NameColor">
                    </div>
                }

            </div>
            </div>
        </div>
    </div>
</div>
