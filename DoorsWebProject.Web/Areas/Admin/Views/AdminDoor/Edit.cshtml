@using DoorsWebProject.Web.ViewModels.Admin.Door
@model FindedDoorViewModel

@{
    ViewData["Title"] = "Edit Door";
}

<h2 class="mb-4">Edit Door</h2>

<form class="formEdit"
      action="/Admin/AdminDoor/Edit"
      method="post">

    <!-- Anti-forgery token (ако ползваш ValidateAntiForgeryToken) -->
    

    <!-- DoorId -->
    <input type="hidden"
           name="DoorId"
           value="@Model.DoorId" />

    <div class="form-group mb-3">
        <label>Model</label>
        <input type="text"
               name="Model"
               class="form-control"
               value="@Model.Model" />
    </div>

    <div class="form-group mb-3">
        <label>Type</label>
        <input type="text"
               name="Type"
               class="form-control"
               value="@Model.Type" />
    </div>

    <div class="form-group mb-3">
        <label>Image URL</label>
        <input type="text"
               name="ImageUrl"
               class="form-control"
               value="@Model.ImageUrl" />
    </div>

    <div class="form-group mb-3">
        <label>Description</label>
        <textarea name="Description"
                  class="form-control">@Model.Description</textarea>
    </div>

    <div class="form-group mb-3">
        <label>Price</label>
        <input type="number"
               step="0.01"
               name="Price"
               class="form-control"
               value="@Model.Price" />
    </div>

    <div class="form-group mb-3">
        <label>Height</label>
        <input type="number"
               step="0.01"
               name="Height"
               class="form-control"
               value="@Model.Height"
               readonly />
    </div>

    <div class="form-group mb-3">
        <label>Width</label>
        <input type="number"
               step="0.01"
               name="Width"
               class="form-control"
               value="@Model.Width"
               readonly />
    </div>

    <div class="form-group mb-3">
        <label>Thickness</label>
        <input type="number"
               step="0.01"
               name="Thickness"
               class="form-control"
               value="@Model.Thickness"
               readonly />
    </div>

    <button type="submit" class="btn btn-primary">Save Changes</button>
    <a href="/Admin/AdminDoor" class="btn btn-secondary ms-2">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}


