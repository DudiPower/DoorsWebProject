@using DoorsWebProject.Web.ViewModels.Admin.Door
@model IEnumerable<DoorAdminViewModel>

@{
    ViewData["Title"] = "Door";
}

<table class="doors-table">
    <thead>
        <tr>
            <th>Снимка</th>
            <th>Име</th>
            <th>Категория</th>
            <th>Цена</th>
            <th>Наличност</th>
            <th>Статус</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var door in Model)
        {
            <tr>
                <td>
                    <img src="@door.ImageUrl" alt="Door image" class="door-thumb" />
                </td>
                <td>@door.Model</td>
                <td>@door.Category</td>
                <td>@door.Price.ToString("F2") лв.</td>

                <td class="stock
                        @(door.Stock == 0
                                            ? "stock-out"
                                            : door.Stock <= 3
                                                ? "stock-low"
                                                : "stock-in")">
                    @door.Stock
                </td>

                <td class="actions">
                    <a asp-page="Edit" asp-route-id="@door.Id" title="Редакция">✏️</a>
                    <a asp-page="Delete" asp-route-id="@door.Id" title="Изтриване">🗑</a>
                    <a asp-page="/Doors/Details" asp-route-id="@door.Id" title="Преглед">👁</a>
                </td>
            </tr>
        }
    </tbody>
</table>
